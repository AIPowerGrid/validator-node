# AIPG Validator Node — copy to .env and `chmod 600 .env`. Never commit .env.

# ── Grid ──
GRID_API_URL=https://grid.aipowergrid.io
# Grid API key for an account with the `validator` role.
VALIDATOR_API_KEY=

# ── Identity / on-chain (Base) ──
VALIDATOR_WALLET=0xYourValidatorAddress
# Private key signs attestations and holds the stake. SECRET. chmod 600 this file.
VALIDATOR_PRIVATE_KEY=
BASE_RPC_URL=https://mainnet.base.org
AIPG_TOKEN_ADDR=0xa1c0deCaFE3E9Bf06A5F29B7015CD373a9854608
# Set once ValidatorStaking is deployed:
VALIDATOR_STAKING_ADDR=
VALIDATOR_MIN_STAKE=50000
# Pre-launch / local dev only — skip the on-chain stake gate:
VALIDATOR_REQUIRE_STAKE=false

# ── Probing ──
PROBE_INTERVAL_S=60
PROBE_TIMEOUT_S=45
PROBE_MAX_TOKENS=256
LATENCY_BUDGET_S=30
